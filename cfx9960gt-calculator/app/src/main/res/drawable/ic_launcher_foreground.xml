<?xml version="1.0" encoding="utf-8"?>
<!--
    Casio CFX-9960GTe – launcher icon foreground.

    The adaptive-icon background is @color/body_bg (#1C2040, dark navy),
    so this foreground layer draws all the surface detail on that body:

      ┌─────────────────────────────────────┐
      │  CASIO            CFX-9960GT        │  ← label blocks (white/grey)
      │ ┌─────────────────────────────────┐ │
      │ │  LCD screen (cream)             │ │  ← screen
      │ │   expression line ▌             │ │
      │ │              0.000              │ │
      │ └─────────────────────────────────┘ │
      │ ██████░░░░░░░░░░░▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓ │  ← orange / green / blue stripe
      │ [F1][F2][F3][F4][F5][F6]           │  ← F-key row
      │ [SH][AL][xθT][MN][▲][AC]           │  ← row 1
      │ [OP][VA][DEL][◄][▼][►]             │  ← row 2
      │ [x²][x⁻¹][log][ln][(-)[EX]         │  ← row 3
      │ [sin][cos][tan][E][HY][∛]           │  ← row 4
      │ [ 7][ 8][ 9][ (][ )][ ÷]           │  ← numeric
      │ [ 4][ 5][ 6][ ×][√ ][ π]           │
      │ [ 1][ 2][ 3][ +][ -][An]           │
      │ [ 0][ .][  ][ M+][   EXE   ]        │
      └─────────────────────────────────────┘

    Viewport: 108 × 108.  Button columns: x = 8..20, 22..34, 36..48, 50..62, 64..76, 78..90.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ══════════════════════════════════════════════════════════════════
         TOP LABEL STRIP
         ═════════════════════════════════════════════════════════════════ -->

    <!-- "CASIO" brand block (white) -->
    <path android:fillColor="#FFFFFF"
          android:pathData="M8,3 L52,3 L52,7 L8,7 Z"/>

    <!-- "CFX-9960GT" model block (silver-grey) -->
    <path android:fillColor="#AAAACC"
          android:pathData="M55,3 L100,3 L100,7 L55,7 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         SCREEN
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Screen bezel (darker surround) -->
    <path android:fillColor="#0A0D26"
          android:pathData="M7,9 L101,9 L101,44 L7,44 Z"/>

    <!-- LCD panel (classic Casio cream-green tint) -->
    <path android:fillColor="#C8CC8C"
          android:pathData="M9,11 L99,11 L99,42 L9,42 Z"/>

    <!-- Screen glare highlight (top strip, lighter) -->
    <path android:fillColor="#DDDFA8"
          android:pathData="M9,11 L99,11 L99,15 L9,15 Z"/>

    <!-- Expression / input line (dark thin bar, left-aligned) -->
    <path android:fillColor="#2A2800"
          android:pathData="M11,18 L72,18 L72,21 L11,21 Z"/>

    <!-- Cursor blink indicator -->
    <path android:fillColor="#2A2800"
          android:pathData="M73,18 L76,18 L76,21 L73,21 Z"/>

    <!-- Result line (larger, right-aligned) -->
    <path android:fillColor="#2A2800"
          android:pathData="M50,26 L97,26 L97,33 L50,33 Z"/>

    <!-- Status indicators row (D = degree, M) -->
    <path android:fillColor="#2A2800"
          android:pathData="M11,36 L18,36 L18,39 L11,39 Z"/>
    <path android:fillColor="#2A2800"
          android:pathData="M20,36 L27,36 L27,39 L20,39 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         CFX THREE-COLOUR STRIPE  (iconic feature of the CFX series)
         ═════════════════════════════════════════════════════════════════ -->

    <!-- Orange third -->
    <path android:fillColor="#FF7700"
          android:pathData="M7,45 L37,45 L37,50 L7,50 Z"/>

    <!-- Green third -->
    <path android:fillColor="#00AA33"
          android:pathData="M38,45 L72,45 L72,50 L38,50 Z"/>

    <!-- Blue third -->
    <path android:fillColor="#0055CC"
          android:pathData="M73,45 L101,45 L101,50 L73,50 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         F1 – F6  FUNCTION KEY ROW
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#111130" android:pathData="M8,52 L20,52 L20,57 L8,57 Z"/>
    <path android:fillColor="#111130" android:pathData="M22,52 L34,52 L34,57 L22,57 Z"/>
    <path android:fillColor="#111130" android:pathData="M36,52 L48,52 L48,57 L36,57 Z"/>
    <path android:fillColor="#111130" android:pathData="M50,52 L62,52 L62,57 L50,57 Z"/>
    <path android:fillColor="#111130" android:pathData="M64,52 L76,52 L76,57 L64,57 Z"/>
    <path android:fillColor="#111130" android:pathData="M78,52 L90,52 L90,57 L78,57 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 1 :  SHIFT  ALPHA  x,θ,T  MENU  ▲  AC
         ═════════════════════════════════════════════════════════════════ -->

    <!-- SHIFT  – deep blue -->
    <path android:fillColor="#334499" android:pathData="M8,59 L20,59 L20,64 L8,64 Z"/>
    <!-- ALPHA  – deep red -->
    <path android:fillColor="#993333" android:pathData="M22,59 L34,59 L34,64 L22,64 Z"/>
    <!-- x,θ,T  – mid grey -->
    <path android:fillColor="#BBBBBB" android:pathData="M36,59 L48,59 L48,64 L36,64 Z"/>
    <!-- MENU   – mid grey -->
    <path android:fillColor="#BBBBBB" android:pathData="M50,59 L62,59 L62,64 L50,64 Z"/>
    <!-- ▲      – mid grey -->
    <path android:fillColor="#BBBBBB" android:pathData="M64,59 L76,59 L76,64 L64,64 Z"/>
    <!-- AC/ON  – dark charcoal -->
    <path android:fillColor="#555555" android:pathData="M78,59 L90,59 L90,64 L78,64 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 2 :  OPTN  VARS  DEL  ◄  ▼  ►
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#999999" android:pathData="M8,66 L20,66 L20,71 L8,71 Z"/>
    <path android:fillColor="#999999" android:pathData="M22,66 L34,66 L34,71 L22,71 Z"/>
    <path android:fillColor="#999999" android:pathData="M36,66 L48,66 L48,71 L36,71 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M50,66 L62,66 L62,71 L50,71 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M64,66 L76,66 L76,71 L64,71 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M78,66 L90,66 L90,71 L78,71 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 3 :  x²  x⁻¹  log  ln  (-)  EXIT
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#AAAAAA" android:pathData="M8,73 L20,73 L20,78 L8,78 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M22,73 L34,73 L34,78 L22,78 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M36,73 L48,73 L48,78 L36,78 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M50,73 L62,73 L62,78 L50,78 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M64,73 L76,73 L76,78 L64,78 Z"/>
    <path android:fillColor="#AAAAAA" android:pathData="M78,73 L90,73 L90,78 L78,78 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 4 :  sin  cos  tan  ×10ˣ  HYP  ∛x
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#BBBBBB" android:pathData="M8,80 L20,80 L20,85 L8,85 Z"/>
    <path android:fillColor="#BBBBBB" android:pathData="M22,80 L34,80 L34,85 L22,85 Z"/>
    <path android:fillColor="#BBBBBB" android:pathData="M36,80 L48,80 L48,85 L36,85 Z"/>
    <path android:fillColor="#BBBBBB" android:pathData="M50,80 L62,80 L62,85 L50,85 Z"/>
    <path android:fillColor="#BBBBBB" android:pathData="M64,80 L76,80 L76,85 L64,85 Z"/>
    <path android:fillColor="#BBBBBB" android:pathData="M78,80 L90,80 L90,85 L78,85 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 5 :  7  8  9  (  )  ÷
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#FFFFFF" android:pathData="M8,87 L20,87 L20,92 L8,92 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M22,87 L34,87 L34,92 L22,92 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M36,87 L48,87 L48,92 L36,92 Z"/>
    <path android:fillColor="#DDDDDD" android:pathData="M50,87 L62,87 L62,92 L50,92 Z"/>
    <path android:fillColor="#DDDDDD" android:pathData="M64,87 L76,87 L76,92 L64,92 Z"/>
    <!-- ÷ : dark operator key -->
    <path android:fillColor="#222222" android:pathData="M78,87 L90,87 L90,92 L78,92 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         ROW 6 :  4  5  6  ×  √x  π
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#FFFFFF" android:pathData="M8,94 L20,94 L20,99 L8,99 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M22,94 L34,94 L34,99 L22,99 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M36,94 L48,94 L48,99 L36,99 Z"/>
    <!-- × : dark operator key -->
    <path android:fillColor="#222222" android:pathData="M50,94 L62,94 L62,99 L50,99 Z"/>
    <path android:fillColor="#CCCCCC" android:pathData="M64,94 L76,94 L76,99 L64,99 Z"/>
    <path android:fillColor="#CCCCCC" android:pathData="M78,94 L90,94 L90,99 L78,99 Z"/>

    <!-- ══════════════════════════════════════════════════════════════════
         BOTTOM ROW :  0  .  ,  M+  [  EXE  ]
         ═════════════════════════════════════════════════════════════════ -->

    <path android:fillColor="#FFFFFF" android:pathData="M8,101 L20,101 L20,106 L8,106 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M22,101 L34,101 L34,106 L22,106 Z"/>
    <path android:fillColor="#FFFFFF" android:pathData="M36,101 L48,101 L48,106 L36,106 Z"/>
    <!-- M+ : dark charcoal -->
    <path android:fillColor="#444444" android:pathData="M50,101 L62,101 L62,106 L50,106 Z"/>
    <!-- EXE : full black, spans two columns -->
    <path android:fillColor="#000000" android:pathData="M64,101 L90,101 L90,106 L64,106 Z"/>

</vector>
