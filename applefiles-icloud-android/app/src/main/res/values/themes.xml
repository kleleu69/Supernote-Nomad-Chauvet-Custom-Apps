<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ICloudAndroid" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <style name="ThemeOverlay.ICloud.Popup" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/black</item>
        <item name="android:colorBackground">@android:color/white</item>
    </style>
</resources> 