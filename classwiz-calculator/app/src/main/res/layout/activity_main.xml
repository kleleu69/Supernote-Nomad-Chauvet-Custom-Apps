<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- ── Display panel ────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/displayPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.26"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <!-- Status / mode row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvShiftIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:visibility="invisible"
                android:paddingRight="6dp" />

            <TextView
                android:id="@+id/tvAlphaIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:visibility="invisible"
                android:paddingRight="6dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvAngleMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEG"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:paddingLeft="8dp" />

            <TextView
                android:id="@+id/tvMemIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:visibility="invisible"
                android:paddingLeft="8dp" />

        </LinearLayout>

        <!-- Expression line (scrollable) -->
        <HorizontalScrollView
            android:id="@+id/exprScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="false">

            <TextView
                android:id="@+id/tvExpr"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="22sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:gravity="center_vertical|end"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </HorizontalScrollView>

        <!-- Result line -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="34sp"
                android:fontFamily="monospace"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingTop="2dp" />

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/black" />

    <!-- ── Button grid (5 × 8) ──────────────────────────────────────────────── -->
    <GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.74"
        android:columnCount="5"
        android:rowCount="8"
        android:useDefaultMargins="false" />

</LinearLayout>
